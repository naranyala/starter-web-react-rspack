{
  "name": "rustwebui-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:direct": "rspack serve",
    "build": "rspack build",
    "preview": "rspack preview",
    "kill-port": "lsof -ti:3000 -ti:8080 -ti:8081 | xargs kill -9 2>/dev/null || true",
    "clean": "rm -rf dist && rm -rf node_modules/.cache",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "format": "biome format src",
    "format:fix": "biome format src --write",
    "check": "biome check src",
    "check:fix": "biome check src --write"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "winbox": "^0.2.82"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@rspack/cli": "^1.7.5",
    "@rspack/core": "^1.7.5",
    "@rspack/plugin-react-refresh": "^1.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}